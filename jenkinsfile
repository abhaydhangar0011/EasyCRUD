pipeline {
    agent any

    stages {

        stage('Pull Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/abhaydhangar0011/EasyCRUD.git'
            }
        }

        stage('Install Maven') {
            steps {
                sh '''
                sudo apt update
                sudo apt install -y maven
                mvn -version
                '''
            }
        }

        stage('Build') {
            steps {
                dir('backend') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
    }
}
