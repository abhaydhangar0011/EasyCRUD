pipeline {
    agent any

    stages {

        stage('Pull Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/abhaydhangar0011/EasyCRUD.git'
            }
        }

        stage('Build') {
            steps {
                sh '''
                cd backend
                mvn clean package -DskipTests
                '''
            }
        }

stage('sonarqube') {
            steps {
                withSonarQubeEnv(installationName: 'sonarqube', credentialsId: 'sonarid') {
                    sh '''
                    cd backend
                    mvn sonar:sonar -Dsonar.projectKey=studentdb
                    '''
                }
            }
        }

  stage('quality gate') {
            steps {
            timeout(5){ 
               waitForQualityGate abortPipeline: true
   }
}
}
stage('deliver') {
            steps {sh '''cd backend/target/
aws s3 cp student-registration-backend-0.0.1-SNAPSHOT.jar s3://deliver-bucket-jenkins/artifacts/student.jar'''
                
            }
        }




    
}
}
