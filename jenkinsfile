pipeline {
    agent any

    stages {

        stage('Pull Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/abhaydhangar0011/EasyCRUD.git'
                echo 'Code Pulled Successfully'
            }
        }

        stage('Build') {
            steps {
            sh '''cd backend
                  apt install maven -y
                  mvn clean package -DskipTests'''
            }
        }

        stage('Test') {
            steps {
                echo 'Running Tests'
                echo 'Tests Passed'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying Application'
                echo 'Deployment Successful'
            }
        }
    }
}
